<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Products List</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <nav class="navbar">
      <div class="container">
        <h1>Product Management System</h1>
        <a href="/" class="nav-link">Home</a>
      </div>
    </nav>

    <main class="container">
      <div class="header-section">
        <h2>Products List</h2>
        <a href="/create" class="btn btn-primary">Add New Product</a>
      </div>

      <% if (message) { %>
      <div
        class="alert <%= message.includes('success') ? 'alert-success' : 'alert-error' %>"
      >
        <%= message %>
      </div>
      <% } %>

      <div class="search-section">
        <form action="/" method="GET" class="search-form">
          <input
            type="text"
            name="search"
            placeholder="Search products..."
            value="<%= query %>"
            class="search-input"
          />
          <button type="submit" class="btn btn-secondary">Search</button>
        </form>
      </div>

      <% if (products.length > 0) { %>
      <div class="table-container">
        <table class="product-table">
          <thead>
            <tr>
              <th>Image</th>
              <th>Name</th>
              <th>Price</th>
              <th>Stock</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% products.forEach(product => { %>
            <tr>
              <td>
                <% if (product.url_image) { %>
                <img
                  src="<%= product.url_image %>"
                  alt="<%= product.name %>"
                  class="product-thumbnail"
                />
                <% } else { %>
                <div class="no-image">No Image</div>
                <% } %>
              </td>
              <td><%= product.name %></td>
              <td>$<%= product.price.toFixed(2) %></td>
              <td><%= product.unit_in_stock %></td>
              <td class="actions">
                <a href="/<%= product.id %>" class="btn btn-info btn-sm"
                  >View</a
                >
                <a href="/<%= product.id %>/edit" class="btn btn-warning btn-sm"
                  >Edit</a
                >
                <form
                  action="/<%= product.id %>/delete"
                  method="POST"
                  style="display: inline"
                  onsubmit="return confirm('Are you sure you want to delete this product?')"
                >
                  <button type="submit" class="btn btn-danger btn-sm">
                    Delete
                  </button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } else { %>
      <div class="empty-state">
        <p>No products found.</p>
        <% if (query) { %>
        <a href="/" class="btn btn-secondary">Clear Search</a>
        <% } %>
      </div>
      <% } %>
    </main>

    <footer
      style="
        font-size: 30;
        display: flex;
        flex-direction: column;
        justify-content: center;
      "
    >
      <p>Họ tên: Nguyễn Huỳnh Thế Bảo</p>
      <p>MSSV: 22690761</p>
    </footer>
  </body>
</html>
